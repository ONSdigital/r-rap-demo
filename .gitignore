# .gitignore for the r.rap.demo RAP project
# This file tells Git which files and folders to ignore (not track in version control).
# Use it to keep your repository clean and avoid sharing sensitive, temporary, or auto-generated files.

# Data and config (if you want to keep local or sensitive files out of Git)
# Uncomment the next lines if you want to ignore local data/config
# Ignore all files in the data folder (e.g., health_data.csv)
# data/
# Ignore all files in the config folder (e.g., user_config.yaml)
# config/

# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/
